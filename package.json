{
  "name": "@particle-academy/fancy-x-files-ui",
  "version": "0.1.0",
  "description": "Headless react-fancy editor suite for the well-known files modeled by fancy-x-files — robots.txt, security.txt, llms.txt, humans.txt, sitemap.xml, AGENTS — controlled, JSON-friendly, Human+ UX",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-x-files-ui.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-x-files-ui#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-x-files-ui/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "@particle-academy/react-fancy": ">=4",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@particle-academy/react-fancy": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
